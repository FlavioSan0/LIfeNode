generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ClientStatus {
  LEAD
  CONTACTED
  PROPOSAL
  ACTIVE
  PAUSED
  FINISHED
}

enum QuickEntryType {
  TASK
  NOTE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  profile      UserProfile?
  areas        Area[]
  projects     Project[]
  clients      Client[]
  tasks        Task[]
  events       Event[]
  notes        Note[]
  activityLogs ActivityLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@unique([token])
}

model UserProfile {
  userId    String   @id
  email     String?
  name      String?
  avatarUrl String?
  timezone  String   @default("America/Sao_Paulo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model Area {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
  tasks    Task[]
  events   Event[]
  notes    Note[]

  @@unique([userId, name])
  @@index([userId])
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  areaId      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  area   Area?  @relation(fields: [areaId], references: [id], onDelete: SetNull)
  tasks  Task[]
  events Event[]
  notes  Note[]

  @@unique([userId, name])
  @@index([userId, status])
  @@index([areaId])
}

model Client {
  id           String       @id @default(cuid())
  userId       String
  name         String
  company      String?
  phone        String?
  email        String?
  serviceType  String?
  status       ClientStatus @default(LEAD)
  observations String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]
  events Event[]
  notes  Note[]

  @@index([userId, status])
  @@index([userId, name])
}

model Task {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  dueTime     String?
  completedAt DateTime?
  cancelledAt DateTime?
  areaId      String?
  projectId   String?
  clientId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  area    Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, priority])
  @@index([areaId])
  @@index([projectId])
  @@index([clientId])
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  areaId      String?
  projectId   String?
  clientId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  area    Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId, startsAt])
  @@index([areaId])
  @@index([projectId])
  @@index([clientId])
}

model Note {
  id        String         @id @default(cuid())
  userId    String
  content   String
  type      QuickEntryType @default(NOTE)
  date      DateTime?
  priority  Priority?
  areaId    String?
  projectId String?
  clientId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  area    Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([areaId])
  @@index([projectId])
  @@index([clientId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, entity])
}
